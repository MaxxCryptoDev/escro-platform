{
  "input_settings": {
    "separator": "---",
    "encoding": "utf-8",
    "auto_detect_articles": true
  },
  "content_generation": {
    "min_title_words": 3,
    "max_title_words": 8,
    "description_sentences": 1,
    "main_content_min_words": 100,
    "main_content_max_words": 120,
    "use_italics": true,
    "language": "ro"
  },
  "api_settings": {
    "model": "claude-3-haiku-20240307",
    "max_tokens": 1500,
    "temperature": 0.7
  },
  "output_settings": {
    "output_dir": "./output",
    "create_markdown": true,
    "create_json_metadata": true
  },
  "logging": {
    "level": "INFO",
    "output_file": "./logs/generator.log"
  }
}
