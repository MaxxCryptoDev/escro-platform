                          <button
                            onClick={async () => {
                              if (window.confirm(`Reject request from ${request.user_name}?`)) {
                                try {
                                  await adminAPI.rejectTaskRequest(request.id);
                                  setRefreshKey(prev => prev + 1);
                                  alert('Task request rejected');
                                } catch (error) {
                                  console.error('Error rejecting request:', error);
                                  alert('Error rejecting request');
                                }
