                  <th style={styles.tableHeader}>Notes</th>
                  <th style={styles.tableHeader}>Action</th>
                </tr>
              </thead>
              <tbody>
                {verificationCalls.map(call => (
                  <tr key={call.id} style={styles.tableRow}>
                    <td style={styles.tableCell}>{call.name}</td>
                    <td style={styles.tableCell}>{call.email}</td>
                    <td style={styles.tableCell}>{call.company || '-'}</td>
                    <td style={styles.tableCell}>{new Date(call.scheduled_date).toLocaleDateString()}</td>
                    <td style={styles.tableCell}>{call.scheduled_time}</td>
                    <td style={styles.tableCell}>
                      <span style={{
                        padding: '0.25rem 0.75rem',
                        borderRadius: '4px',
                        backgroundColor: call.status === 'completed' ? '#28a745' : call.status === 'cancelled' ? '#dc3545' : '#ffc107',
                        color: 'white',
                        fontSize: '12px',
                        fontWeight: 'bold'
                      }}>
                        {call.status}
                      </span>
                    </td>
                    <td style={styles.tableCell}>{call.notes || '-'}</td>
                    <td style={{...styles.tableCell, display: 'flex', gap: '0.5rem'}}>
                      <button
                        onClick={() => {
                          console.log('[DEBUG] Call object:', call);
                          console.log('[DEBUG] call.user_id:', call.user_id);
                          if (window.confirm(`Approve verification for ${call.name}?`)) {
                            handleVerifyExpert(call.user_id, 'verified');
                          }
                        }}
                        style={{
                          padding: '0.5rem 1rem',
                          backgroundColor: '#28a745',
                          color: 'white',
                          border: 'none',
                          borderRadius: '4px',
                          cursor: 'pointer',
                          fontSize: '12px'
                        }}
                      >
                        ✓ Approve
                      </button>
                      <button
                        onClick={() => {
                          if (window.confirm(`Reject verification for ${call.name}?`)) {
                            handleVerifyExpert(call.user_id, 'rejected');
                          }
                        }}
                        style={{
                          padding: '0.5rem 1rem',
                          backgroundColor: '#dc3545',
                          color: 'white',
                          border: 'none',
                          borderRadius: '4px',
                          cursor: 'pointer',
                          fontSize: '12px'
                        }}
                      >
                        ✗ Reject
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      )}

      {/* TASK REQUESTS TAB */}
      {activeTab === 'task-requests' && (
        <div style={styles.section}>
          <h2>📝 Task Participation Requests</h2>
          {taskRequests.length === 0 ? (
            <p style={{ color: '#666' }}>No task requests yet</p>
          ) : (
            <table style={styles.table}>
              <thead>
                <tr style={styles.tableHeaderRow}>
                  <th style={styles.tableHeader}>Expert/Company</th>
                  <th style={styles.tableHeader}>Email</th>
                  <th style={styles.tableHeader}>Project</th>
                  <th style={styles.tableHeader}>Client</th>
                  <th style={styles.tableHeader}>Message</th>
                  <th style={styles.tableHeader}>Status</th>
                  <th style={styles.tableHeader}>Requested Date</th>
                  <th style={styles.tableHeader}>Actions</th>
                </tr>
              </thead>
              <tbody>
                {taskRequests.map(request => (
                  <tr key={request.id} style={styles.tableRow}>
                    <td style={styles.tableCell}>
                      <strong>{request.user_name}</strong>
                      <br />
                      <small style={{ color: '#666' }}>{request.role}</small>
                    </td>
                    <td style={styles.tableCell}>{request.user_email}</td>
                    <td style={styles.tableCell}>
                      <strong>{request.project_title}</strong>
                      <br />
                      <small style={{ color: '#666' }}>{request.project_description?.substring(0, 50)}...</small>
                    </td>
                    <td style={styles.tableCell}>{request.client_name}</td>
                    <td style={styles.tableCell}>
                      {request.message ? (
                        <div style={{ maxWidth: '200px', whiteSpace: 'pre-wrap', wordBreak: 'break-word', fontSize: '12px' }}>
                          {request.message}
                        </div>
                      ) : (
                        <em style={{ color: '#999' }}>No message</em>
                      )}
                    </td>
                    <td style={styles.tableCell}>
                      <span style={{
                        padding: '0.25rem 0.75rem',
                        borderRadius: '4px',
                        backgroundColor: 
                          request.status === 'approved' ? '#28a745' :
                          request.status === 'rejected' ? '#dc3545' :
                          request.status === 'cancelled' ? '#6c757d' :
                          '#ffc107',
                        color: 'white',
                        fontSize: '12px',
                        fontWeight: 'bold'
                      }}>
                        {request.status}
                      </span>
