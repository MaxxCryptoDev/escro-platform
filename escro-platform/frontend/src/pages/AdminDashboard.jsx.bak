                              }
                            }}
                            style={{
                              padding: '0.25rem 0.75rem',
                              backgroundColor: '#0056b3',
                              color: 'white',
                              border: 'none',
                              borderRadius: '4px',
                              cursor: 'pointer',
                              fontSize: '12px',
                              fontWeight: 'bold'
                            }}
                          >
                            👤 Assign Company
                          </button>
                        </div>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      )}

      {/* ASSIGN EXPERT TAB */}
      {activeTab === 'assign-expert' && (
        <div style={styles.section}>
          <h2>✨ Manually Assign Expert/Company to Project</h2>
          
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '2rem', marginBottom: '2rem' }}>
            {/* Projects without expert */}
            <div>
              <h3>Projects Needing Assignment</h3>
              <div style={{ border: '1px solid #ddd', borderRadius: '4px', maxHeight: '400px', overflowY: 'auto' }}>
                {allProjects.filter(p => !p.expert_id).length === 0 ? (
                  <p style={{ padding: '1rem', color: '#666' }}>All projects have experts/companies assigned</p>
                ) : (
                  allProjects.filter(p => !p.expert_id).map(project => (
                    <div
                      key={project.id}
                      onClick={() => setSelectedProjectForAssignment(project)}
                      style={{
                        padding: '1rem',
                        borderBottom: '1px solid #eee',
                        cursor: 'pointer',
                        backgroundColor: selectedProjectForAssignment?.id === project.id ? '#e7f3ff' : 'white',
                        transition: 'background-color 0.2s'
                      }}
                    >
                      <strong>{project.title}</strong>
                      <p style={{ margin: '0.5rem 0 0 0', fontSize: '0.85rem', color: '#666' }}>
                        Budget: {project.budget_ron} RON
                      </p>
                    </div>
                  ))
                )}
              </div>
            </div>

            {/* Available experts and companies */}
            <div>
              <h3>Available Resources (Experts & Companies)</h3>
              <div style={{ border: '1px solid #ddd', borderRadius: '4px', maxHeight: '400px', overflowY: 'auto' }}>
                {allUsers.filter(u => (u.role === 'expert' || u.role === 'client') && u.kyc_status === 'verified').length === 0 ? (
                  <p style={{ padding: '1rem', color: '#666' }}>No verified experts or companies available</p>
                ) : (
                  allUsers.filter(u => (u.role === 'expert' || u.role === 'client') && u.kyc_status === 'verified').map(resource => (
                    <div
                      key={resource.id}
                      onClick={() => setSelectedExpertForAssignment(resource)}
                      style={{
                        padding: '1rem',
                        borderBottom: '1px solid #eee',
                        cursor: 'pointer',
                        backgroundColor: selectedExpertForAssignment?.id === resource.id ? '#e7f3ff' : 'white',
                        transition: 'background-color 0.2s'
                      }}
                    >
                      <strong>{resource.name}</strong>
                      <p style={{ margin: '0.25rem 0', fontSize: '0.85rem', color: '#666' }}>
                        {resource.role === 'expert' ? '👤 Expert' : '🏢 Company'} {resource.company && `- ${resource.company}`}
                      </p>
                      <p style={{ margin: '0.25rem 0 0 0', fontSize: '0.85rem', color: '#666' }}>
                        {resource.email}
                      </p>
                    </div>
                  ))
                )}
              </div>
            </div>
          </div>

          {/* Assignment Info */}
          {selectedProjectForAssignment && selectedExpertForAssignment && (
            <div style={{ backgroundColor: '#f0f8ff', padding: '1.5rem', borderRadius: '4px', marginBottom: '1.5rem', border: '2px solid #007bff' }}>
              <p style={{ margin: '0 0 1rem 0' }}>
                <strong>Project:</strong> {selectedProjectForAssignment.title}
              </p>
              <p style={{ margin: '0 0 1rem 0' }}>
                <strong>Assigning to:</strong> {selectedExpertForAssignment.name} ({selectedExpertForAssignment.role === 'expert' ? '👤 Expert' : '🏢 Company'}) - {selectedExpertForAssignment.email}
              </p>
              <button
                onClick={async () => {
                  try {
                    await axios.put(
                      `http://localhost:5000/api/admin/projects/${selectedProjectForAssignment.id}/assign-expert`,
                      { expert_id: selectedExpertForAssignment.id },
                      { headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` } }
                    );
                    alert(`${selectedExpertForAssignment.role === 'expert' ? 'Expert' : 'Company'} assigned successfully!`);
                    setSelectedProjectForAssignment(null);
                    setSelectedExpertForAssignment(null);
                    setRefreshKey(prev => prev + 1);
                  } catch (error) {
                    console.error('Error assigning resource:', error);
                    alert('Error assigning resource: ' + error.message);
                  }
                }}
                style={{
                  padding: '0.75rem 1.5rem',
                  backgroundColor: '#28a745',
                  color: 'white',
                  border: 'none',
                  borderRadius: '4px',
                  cursor: 'pointer',
                  fontWeight: 'bold',
                  fontSize: '1rem'
                }}
              >
                ✓ Assign {selectedExpertForAssignment?.role === 'expert' ? 'Expert' : 'Company'}
              </button>
            </div>
          )}
        </div>
      )}

      {/* Expert Profile Modal */}
      {showExpertModal && selectedExpert && (
        <div style={{
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          bottom: 0,
          backgroundColor: 'rgba(0, 0, 0, 0.6)',
          display: 'flex',
          justifyContent: 'center',
          alignItems: 'center',
          zIndex: 1000
        }}>
          <div style={{
            background: 'white',
            borderRadius: '12px',
            boxShadow: '0 10px 40px rgba(0, 0, 0, 0.2)',
            maxWidth: '600px',
            width: '90%',
            maxHeight: '90vh',
            overflowY: 'auto',
            padding: '24px'
          }}>
            <div style={{
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center',
              marginBottom: '20px'
            }}>
              <h2 style={{ margin: 0 }}>Expert Profile</h2>
              <button
                onClick={() => {
                  setShowExpertModal(false);
                  setSelectedExpert(null);
                }}
                style={{
                  background: 'none',
                  border: 'none',
                  fontSize: '24px',
                  cursor: 'pointer'
                }}
              >
                ✕
              </button>
            </div>

            <div style={{ marginBottom: '20px' }}>
              <h3 style={{ margin: '0 0 10px 0' }}>{selectedExpert.user_name}</h3>
              <p style={{ margin: '5px 0', color: '#666' }}>
                <strong>Email:</strong> {selectedExpert.user_email}
              </p>
              <p style={{ margin: '5px 0', color: '#666' }}>
                <strong>Role:</strong> {selectedExpert.role}
              </p>
              {selectedExpert.company && (
                <p style={{ margin: '5px 0', color: '#666' }}>
                  <strong>Company:</strong> {selectedExpert.company}
                </p>
              )}
            </div>

            <div style={{
              backgroundColor: '#f8f9fa',
              padding: '16px',
              borderRadius: '8px',
              marginBottom: '20px'
            }}>
              <h4 style={{ margin: '0 0 10px 0' }}>Project Details</h4>
              <p style={{ margin: '5px 0', color: '#333' }}>
                <strong>{selectedExpert.project_title}</strong>
              </p>
              <p style={{ margin: '5px 0', fontSize: '14px', color: '#666' }}>
                {selectedExpert.project_description}
              </p>
              <p style={{ margin: '10px 0 0 0', color: '#666' }}>
                <strong>Client:</strong> {selectedExpert.client_name}
              </p>
            </div>

            {selectedExpert.message && (
              <div style={{
                backgroundColor: '#e7f3ff',
                padding: '16px',
                borderRadius: '8px',
                marginBottom: '20px',
                borderLeft: '4px solid #007bff'
              }}>
                <h4 style={{ margin: '0 0 10px 0' }}>Expert's Message</h4>
                <p style={{ margin: 0, whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>
                  {selectedExpert.message}
                </p>
              </div>
            )}

            <div style={{
              display: 'flex',
              gap: '12px',
              justifyContent: 'flex-end'
            }}>
              <button
                onClick={() => {
                  setShowExpertModal(false);
                  setSelectedExpert(null);
                }}
                style={{
                  padding: '10px 20px',
                  backgroundColor: '#6c757d',
                  color: 'white',
                  border: 'none',
                  borderRadius: '6px',
                  cursor: 'pointer',
                  fontWeight: 'bold'
                }}
              >
                Cancel
              </button>
              <button
                onClick={async () => {
                  try {
                    await axios.put(`http://localhost:5000/api/task-requests/${selectedExpert.id}/status`, 
                      { status: 'approved' },
                      { headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` } }
                    );
                    setShowExpertModal(false);
                    setSelectedExpert(null);
                    setRefreshKey(prev => prev + 1);
                  } catch (error) {
                    console.error('Error approving request:', error);
                    alert('Error approving request: ' + error.message);
                  }
                }}
                style={{
                  padding: '10px 20px',
                  backgroundColor: '#28a745',
                  color: 'white',
                  border: 'none',
                  borderRadius: '6px',
                  cursor: 'pointer',
                  fontWeight: 'bold'
                }}
              >
                ✓ Approve & Assign
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

