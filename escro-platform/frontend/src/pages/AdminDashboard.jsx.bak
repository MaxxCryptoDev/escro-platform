            <p style={{ color: '#666' }}>No expert posted tasks pending approval</p>
          ) : (
            <table style={styles.table}>
              <thead>
                <tr style={styles.tableHeaderRow}>
                  <th style={styles.tableHeader}>Expert Name</th>
                  <th style={styles.tableHeader}>Email</th>
                  <th style={styles.tableHeader}>Task Title</th>
                  <th style={styles.tableHeader}>Description</th>
                  <th style={styles.tableHeader}>Budget</th>
                  <th style={styles.tableHeader}>Timeline</th>
                  <th style={styles.tableHeader}>Status</th>
                  <th style={styles.tableHeader}>Actions</th>
                </tr>
              </thead>
              <tbody>
                {expertPostedTasks.map(task => (
                  <tr key={task.id} style={styles.tableRow}>
                    <td style={styles.tableCell}>
                      <strong>{task.expert_name}</strong>
                    </td>
                    <td style={styles.tableCell}>{task.expert_email}</td>
                    <td style={styles.tableCell}>
                      <strong>{task.title}</strong>
                    </td>
                    <td style={styles.tableCell}>
                      {task.description.substring(0, 50)}...
                    </td>
                    <td style={styles.tableCell}>{task.budget_ron} RON</td>
                    <td style={styles.tableCell}>{task.timeline_days} days</td>
                    <td style={styles.tableCell}>
                      <span style={{
                        padding: '0.25rem 0.75rem',
                        borderRadius: '4px',
                        backgroundColor: 
                          task.expert_posting_status === 'pending' ? '#ffc107' :
                          task.expert_posting_status === 'approved' ? '#28a745' :
                          '#dc3545',
                        color: 'white',
                        fontSize: '12px',
                        fontWeight: 'bold'
                      }}>
                        {task.expert_posting_status === 'pending' ? '⏳ Pending' : task.expert_posting_status === 'approved' ? '✓ Approved' : '✗ Rejected'}
                      </span>
                    </td>
                    <td style={styles.tableCell}>
                      {task.expert_posting_status === 'pending' && (
                        <div style={{ display: 'flex', gap: '0.5rem' }}>
                          <button
                            onClick={async () => {
                              if (window.confirm(`Approve this task from ${task.expert_name}?`)) {
                                try {
                                  await adminAPI.approveExpertPostedTask(task.id);
                                  setRefreshKey(prev => prev + 1);
                                  alert('Expert posted task approved!');
                                } catch (error) {
                                  console.error('Error approving task:', error);
                                  alert('Error approving task');
                                }
                              }
                            }}
                            style={{
                              padding: '0.25rem 0.75rem',
                              backgroundColor: '#28a745',
                              color: 'white',
                              border: 'none',
                              borderRadius: '4px',
                              cursor: 'pointer',
                              fontSize: '12px',
                              fontWeight: 'bold'
                            }}
                          >
                            ✓ Approve
                          </button>
                          <button
                            onClick={async () => {
                              if (window.confirm(`Reject this task from ${task.expert_name}?`)) {
                                try {
                                  await adminAPI.rejectExpertPostedTask(task.id, { reason: 'Rejected by admin' });
                                  setRefreshKey(prev => prev + 1);
                                  alert('Expert posted task rejected');
                                } catch (error) {
                                  console.error('Error rejecting task:', error);
                                  alert('Error rejecting task');
                                }
                              }
                            }}
