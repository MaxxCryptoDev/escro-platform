                              padding: '0.25rem 0.75rem',
                              backgroundColor: '#dc3545',
                              color: 'white',
                              border: 'none',
                              borderRadius: '4px',
                              cursor: 'pointer',
                              fontSize: '12px',
                              fontWeight: 'bold'
                            }}
                          >
                            ✗ Reject
                          </button>
                        </div>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      )}

      {/* CLIENT POSTED TASKS TAB */}
      {activeTab === 'client-posted-tasks' && (
        <div style={styles.section}>
          <h2>🏢 Company Posted Tasks (Pending Approval)</h2>
          {clientPostedTasks.length === 0 ? (
            <p style={{ color: '#666' }}>No company posted tasks pending approval</p>
          ) : (
            <table style={styles.table}>
              <thead>
