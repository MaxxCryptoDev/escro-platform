                          <strong style={{ color: '#2563eb', display: 'block', fontSize: '1.1rem' }}>{task.milestone_count} milestones</strong>
                        </div>
                        <div>
                          <span style={styles.projectMeta}>📅 Posted:</span>
                          <strong style={{ color: '#2563eb', display: 'block', fontSize: '0.95rem' }}>
